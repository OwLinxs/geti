# ==========================================================================
# SIGE-TI - Configuração do Backend (exemplo)
# Copie este arquivo para .env e ajuste os valores conforme o ambiente.
# ==========================================================================

# --- Servidor ---
PORT=8080
# debug (desenvolvimento) ou release (produção)
GIN_MODE=debug

# --- Banco de Dados ---
# Driver: "sqlite" (padrão) ou "postgres".
# A troca entre bancos é APENAS configuração; o código abstrai o dialeto.
DB_DRIVER=sqlite

# DSN (string de conexão):
#  - sqlite:   caminho do arquivo, ex.: sige-ti.db ou /var/lib/sige-ti/sige-ti.db
#  - postgres: host=localhost user=sige password=sige dbname=sige_ti port=5432 sslmode=disable TimeZone=America/Sao_Paulo
DB_DSN=sige-ti.db

# --- Autenticação JWT ---
# OBRIGATÓRIO em produção (GIN_MODE=release). Use ao menos 16 caracteres.
# Em dev, se vazio, usa um valor padrão INSEGURO apenas para não travar o boot.
# Gere um valor forte: openssl rand -base64 48
JWT_SECRET=troque-este-segredo-por-um-valor-aleatorio-seguro
# Validade do token em horas.
JWT_EXPIRES_HOURS=8

# --- Administrador inicial (seed base) ---
ADMIN_NOME=Administrador do Sistema
ADMIN_EMAIL=admin@sige-ti.local
# OBRIGATÓRIA em produção. Em dev, se vazia, usa "admin123". TROQUE após o
# primeiro acesso na tela de Usuários.
ADMIN_SENHA=

# --- Seed ---
# Seed BASE (admin + categorias + setores) roda na 1ª execução.
# SEED_DEMO=true insere dados FICTÍCIOS (itens/movimentações) — só em dev.
# É PROIBIDO em produção (GIN_MODE=release): o boot falha se ativado.
SEED_DEMO=false
# Roda o seed automaticamente na inicialização (idempotente).
SEED_ON_START=false

# --- Rate limiting do login (mitigação de força bruta) ---
# Até LOGIN_RATE_LIMITE tentativas por IP a cada LOGIN_RATE_JANELA_SEG segundos.
LOGIN_RATE_LIMITE=10
LOGIN_RATE_JANELA_SEG=60

# --- CORS ---
# Origens permitidas, separadas por vírgula (frontend Vite roda em 5173).
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Termo de Responsabilidade (PDF) - PARAMETRIZÁVEL, sem hardcode ---
PREFEITURA_NOME=Prefeitura Municipal de Exemplo
PREFEITURA_DEPTO=Departamento de Tecnologia da Informação
# Caminho do brasão/logo para o cabeçalho do PDF (PNG/JPG). Deixe vazio se não houver.
PREFEITURA_LOGO_PATH=
TERMO_CABECALHO=Termo de Responsabilidade de Equipamento
# Cidade/UF usada no fecho do termo, ex.: "Francisco Beltrão/PR"
TERMO_CIDADE_UF=
