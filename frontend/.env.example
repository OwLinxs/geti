# URL base da API do backend SIGE-TI.
# Em desenvolvimento, deixe vazio para usar o proxy do Vite (/api -> http://localhost:8080).
# Em produção, aponte para a URL pública da API, ex.: https://sige-ti.prefeitura.gov.br
VITE_API_BASE_URL=

# Alvo do proxy de desenvolvimento (usado apenas pelo vite.config.ts em dev).
VITE_PROXY_TARGET=http://localhost:8080
