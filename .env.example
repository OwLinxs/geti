# ==========================================================================
# SIGE-TI - Configuração do docker-compose (deploy em rede interna)
#
# Copie este arquivo para .env e ajuste os valores. O docker-compose lê o .env
# automaticamente. NUNCA versione o arquivo .env (ele contém segredos).
#
#   cp .env.example .env
#   nano .env            # ajuste JWT_SECRET, ADMIN_SENHA, etc.
#   docker compose up -d --build
# ==========================================================================

# --- Banco de dados ---
# "sqlite" (padrão, arquivo em volume) ou "postgres".
DB_DRIVER=sqlite
# SQLite (dentro do container): /app/data/sige-ti.db (persistido no volume).
# Postgres: host=postgres user=sige password=SUASENHA dbname=sige_ti port=5432 sslmode=disable TimeZone=America/Sao_Paulo
DB_DSN=/app/data/sige-ti.db

# --- Segurança (OBRIGATÓRIO) ---
# Segredo de assinatura do JWT. Gere um valor aleatório forte, por exemplo:
#   openssl rand -base64 48
# Mínimo de 16 caracteres. SEM ESTE VALOR o backend não sobe em produção.
JWT_SECRET=
# Validade do token de sessão, em horas.
JWT_EXPIRES_HOURS=8

# --- Administrador inicial (criado no primeiro boot) ---
ADMIN_NOME=Administrador do Sistema
ADMIN_EMAIL=admin@sige-ti.local
# Senha inicial do administrador. OBRIGATÓRIA em produção. Defina uma senha
# forte e TROQUE-A após o primeiro acesso (tela de Usuários).
ADMIN_SENHA=

# --- Rate limiting do login (mitigação de força bruta) ---
# Até LOGIN_RATE_LIMITE tentativas por IP a cada LOGIN_RATE_JANELA_SEG segundos.
LOGIN_RATE_LIMITE=10
LOGIN_RATE_JANELA_SEG=60

# --- CORS ---
# Origem(ns) permitida(s), separadas por vírgula. Em rede interna, use o
# IP/hostname do servidor, ex.: http://192.168.0.50
CORS_ALLOWED_ORIGINS=http://localhost

# --- Termo de Responsabilidade (PDF) ---
PREFEITURA_NOME=Prefeitura Municipal de Exemplo
PREFEITURA_DEPTO=Departamento de Tecnologia da Informação
# Caminho do brasão/logo no container (monte em ./backend/assets). Ex.: /app/assets/brasao.png
PREFEITURA_LOGO_PATH=
TERMO_CABECALHO=Termo de Responsabilidade de Equipamento
# Cidade/UF do fecho do termo, ex.: Francisco Beltrão/PR
TERMO_CIDADE_UF=

# --- PostgreSQL (apenas se DB_DRIVER=postgres) ---
# POSTGRES_USER=sige
# POSTGRES_PASSWORD=
# POSTGRES_DB=sige_ti
